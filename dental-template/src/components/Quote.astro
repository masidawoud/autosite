---
interface Props {
  data: {
    text: string;
    author_name: string;
    author_role: string;
  };
}
const { data } = Astro.props;
---

<section class="quote-section">
  <div class="container--narrow quote-inner">
    <blockquote class="quote__text">"{data.text}"</blockquote>
    <hr class="divider" />
    <cite class="quote__cite">
      <span class="quote__name">{data.author_name}</span>
      <span class="quote__role">{data.author_role}</span>
    </cite>
  </div>
</section>

<style>
  .quote-section {
    padding-block: clamp(5rem, 10vw, 9rem);
    background: var(--color-bg-alt);
  }

  .quote-inner { text-align: center; }

  .quote__text {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 3vw, 2.125rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-text);
    max-width: 56ch;
    margin-inline: auto;
  }

  .divider { margin-inline: auto; }

  .quote__cite {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-style: normal;
    align-items: center;
  }

  .quote__name {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .quote__role {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
  }
</style>
