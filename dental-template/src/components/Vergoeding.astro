---
interface Block {
  title: string;
  text: string;
}

interface Props {
  data: {
    eyebrow: string;
    title: string;
    intro: string;
    blocks: Block[];
    insurers: string[];
    cta: string;
  };
}
const { data } = Astro.props;
---

<section class="vergoeding section" id="vergoeding">
  <div class="container vergoeding__grid">

    <div class="vergoeding__content">
      <span class="eyebrow">{data.eyebrow}</span>
      <h2 class="vergoeding__title">{data.title}</h2>
      <p class="vergoeding__intro">{data.intro}</p>

      <div class="vergoeding__blocks">
        {data.blocks.map(b => (
          <div class="vergoeding__block">
            <h4>{b.title}</h4>
            <p>{b.text}</p>
          </div>
        ))}
      </div>

      <a href="#contact" class="btn btn-primary">{data.cta}</a>
    </div>

    <div class="vergoeding__insurers">
      <p class="eyebrow vergoeding__insurers-label">Wij werken samen met</p>
      <div class="vergoeding__insurers-grid">
        {data.insurers.map(v => (
          <span class="insurer-tag">{v}</span>
        ))}
      </div>
      <p class="vergoeding__insurers-note">
        …en meer dan 20 andere verzekeraars.
        Neem contact op voor uw specifieke situatie.
      </p>
    </div>

  </div>
</section>

<style>
  .vergoeding { background: var(--color-bg-alt); }

  .vergoeding__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .vergoeding__content { display: flex; flex-direction: column; gap: 1.5rem; }
  .vergoeding__title { margin-top: 0.5rem; }
  .vergoeding__intro { font-size: 1.0625rem; max-width: 44ch; }

  .vergoeding__blocks { display: flex; flex-direction: column; gap: 1rem; }

  .vergoeding__block {
    padding: 1.375rem 1.5rem;
    background: var(--color-bg);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--color-accent);
  }

  .vergoeding__block h4 {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }

  .vergoeding__block p { font-size: 0.9rem; line-height: 1.65; max-width: none; }

  .vergoeding__insurers { display: flex; flex-direction: column; gap: 1.125rem; padding-top: 0.625rem; }

  .vergoeding__insurers-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .insurer-tag {
    display: inline-block;
    padding: 0.4375rem 1rem;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .vergoeding__insurers-note { font-size: 0.875rem; color: var(--color-text-muted); max-width: none; line-height: 1.6; }

  @media (max-width: 768px) { .vergoeding__grid { grid-template-columns: 1fr; } }
</style>
