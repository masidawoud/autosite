---
import { marked } from 'marked';
const { data } = Astro.props;
const html = marked(data.content ?? '');
---

<section class="richtext-section">
  <div class="container container--narrow">
    <div class="richtext" set:html={html} />
  </div>
</section>

<style>
  .richtext-section {
    padding-block: clamp(4rem, 8vw, 7rem);
  }
  .richtext {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text);
  }
  .richtext :global(h1) { font-family: var(--font-display); margin-bottom: clamp(2rem, 4vw, 3rem); }
  .richtext :global(h2) { margin-top: 2.5rem; margin-bottom: 0.75rem; }
  .richtext :global(h3) { margin-top: 2rem;   margin-bottom: 0.5rem;  }
  .richtext :global(p)  { margin-bottom: 1rem; }
  .richtext :global(ul),
  .richtext :global(ol) { margin-bottom: 1rem; padding-left: 1.5rem; }
  .richtext :global(li) { margin-bottom: 0.25rem; }
  .richtext :global(a)  { color: var(--color-accent); text-decoration: underline; }
  .richtext :global(strong) { font-weight: 600; }
</style>
