---
interface FeatureItem {
  icon: string;
  title: string;
  desc: string;
}

interface Props {
  data: {
    eyebrow: string;
    title: string;
    subtitle: string;
    image_url: string;
    items: FeatureItem[];
  };
}
const { data } = Astro.props;

// Icon map: keys used in site.json → SVG strings
const icons: Record<string, string> = {
  shield: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  clock:  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  team:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  tech:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  heart:  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  card:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
};
---

<section class="features section" id="over-ons">
  <div class="container features__grid">

    <div class="features__image-col">
      <div class="features__image-wrapper">
        <img
          src={data.image_url}
          alt="Het team van de praktijk"
          class="features__img"
          width="640"
          height="780"
          loading="lazy"
        />
      </div>
    </div>

    <div class="features__text-col">
      <span class="eyebrow">{data.eyebrow}</span>
      <h2 class="features__title">{data.title}</h2>
      <p class="features__lead">{data.subtitle}</p>
      <div class="features__list">
        {data.items.map(f => (
          <div class="feature-item">
            <div class="feature-item__icon" set:html={icons[f.icon] ?? icons.shield} />
            <div class="feature-item__body">
              <h4 class="feature-item__title">{f.title}</h4>
              <p class="feature-item__desc">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .features__grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }

  .features__image-wrapper {
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 5 / 6;
    background: var(--color-bg-alt);
  }

  .features__img { width: 100%; height: 100%; object-fit: cover; }

  .features__text-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .features__title { margin-top: 0.5rem; }
  .features__lead { font-size: 1.0625rem; margin-top: -0.25rem; }

  .features__list {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
    margin-top: 0.375rem;
  }

  .feature-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .feature-item__icon {
    flex-shrink: 0;
    width: 2.375rem;
    height: 2.375rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.1rem;
  }

  .feature-item__body { display: flex; flex-direction: column; gap: 0.2rem; }

  .feature-item__title {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .feature-item__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    max-width: none;
  }

  @media (max-width: 900px) {
    .features__grid { grid-template-columns: 1fr; }
    .features__image-wrapper { aspect-ratio: 4 / 3; border-radius: var(--radius-lg); }
  }
</style>
