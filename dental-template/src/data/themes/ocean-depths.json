{
  "preset": "ocean-depths",
  "fonts": {
    "display_family": "Playfair Display",
    "display_url": "Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500",
    "body_family": "Inter",
    "body_url": "Inter:wght@300;400;500;600",
    "display_fallback": "Georgia, serif",
    "body_fallback": "system-ui, -apple-system, sans-serif"
  },
  "colors": {
    "accent":       "#2D8B8B",
    "accent_hover": "#226E6E",
    "accent_light": "#D4EEEE",
    "bg":           "#F1FAEE",
    "bg_alt":       "#E2F2F3",
    "bg_dark":      "#1A2332",
    "text":         "#1A2332",
    "text_muted":   "#4A6070",
    "text_light":   "#F1FAEE",
    "border":       "#C2DCDD",
    "star":         "#F5A623"
  },
  "radius": {
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2.5rem"
  }
}
