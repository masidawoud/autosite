{
  "preset": "tech-innovation",
  "fonts": {
    "display_family": "Space Grotesk",
    "display_url": "Space+Grotesk:wght@300;400;500;600;700",
    "body_family": "Inter",
    "body_url": "Inter:wght@300;400;500;600",
    "display_fallback": "system-ui, -apple-system, sans-serif",
    "body_fallback": "system-ui, -apple-system, sans-serif"
  },
  "colors": {
    "accent":       "#0057DB",
    "accent_hover": "#0044BB",
    "accent_light": "#E8F0FF",
    "bg":           "#FFFFFF",
    "bg_alt":       "#F0F4FF",
    "bg_dark":      "#1E1E1E",
    "text":         "#1E1E1E",
    "text_muted":   "#5A6080",
    "text_light":   "#FFFFFF",
    "border":       "#DDE5FF",
    "star":         "#F5A623"
  },
  "radius": {
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem"
  }
}
